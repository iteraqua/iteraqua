---
import type { Language } from '@/i18n/utils';
import { t } from '@/i18n/utils';

interface Props {
  lang: Language;
}

const { lang } = Astro.props;

const differentiators = [
  {
    titleKey: 'why_iteraqua.item_1_title',
    descKey: 'why_iteraqua.item_1_desc',
    icon: 'engineering',
  },
  {
    titleKey: 'why_iteraqua.item_2_title',
    descKey: 'why_iteraqua.item_2_desc',
    icon: 'precision',
  },
  {
    titleKey: 'why_iteraqua.item_3_title',
    descKey: 'why_iteraqua.item_3_desc',
    icon: 'execution',
  },
  {
    titleKey: 'why_iteraqua.item_4_title',
    descKey: 'why_iteraqua.item_4_desc',
    icon: 'safety',
  },
  {
    titleKey: 'why_iteraqua.item_5_title',
    descKey: 'why_iteraqua.item_5_desc',
    icon: 'reliability',
  },
];

const iconPaths: Record<string, string> = {
  engineering:
    'M19.428 15.428a2 2 0 00-1.022-.547l-2.387-.477a6 6 0 00-3.86.517l-.318.158a6 6 0 01-3.86.517L6.05 15.21a2 2 0 00-1.806.547M8 4h8l-1 1v5.172a2 2 0 00.586 1.414l5 5c1.26 1.26.367 3.414-1.415 3.414H4.828c-1.782 0-2.674-2.154-1.414-3.414l5-5A2 2 0 009 10.172V5L8 4z M12 2v2M8 2h8',
  precision:
    'M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z',
  execution:
    'M13 10V3L4 14h7v7l9-11h-7z M5 3l14 14',
  safety:
    'M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z',
  reliability:
    'M9 12l2 2 4-4M7.835 4.697a3.42 3.42 0 001.946-.806 3.42 3.42 0 014.438 0 3.42 3.42 0 001.946.806 3.42 3.42 0 013.138 3.138 3.42 3.42 0 00.806 1.946 3.42 3.42 0 010 4.438 3.42 3.42 0 00-.806 1.946 3.42 3.42 0 01-3.138 3.138 3.42 3.42 0 00-1.946.806 3.42 3.42 0 01-4.438 0 3.42 3.42 0 00-1.946-.806 3.42 3.42 0 01-3.138-3.138 3.42 3.42 0 00-.806-1.946 3.42 3.42 0 010-4.438 3.42 3.42 0 00.806-1.946 3.42 3.42 0 013.138-3.138z',
};
---

<section class="bg-navy-900 relative overflow-hidden" aria-labelledby="why-iteraqua-heading">
  <div class="absolute inset-0 bg-[url('/images/pattern-waves.svg')] opacity-[0.02]" aria-hidden="true"></div>
  <div class="absolute top-0 right-0 w-96 h-96 bg-aqua-500/5 rounded-full blur-3xl -translate-y-1/2 translate-x-1/2" aria-hidden="true"></div>

  <div class="container-default relative py-16 md:py-20 lg:py-28">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-20 items-start">
      <div class="animate-on-scroll">
        <p class="text-aqua-400 text-sm font-semibold uppercase tracking-wider mb-3">
          Iteraqua
        </p>
        <h2
          id="why-iteraqua-heading"
          class="section-heading text-white text-3xl md:text-4xl lg:text-5xl"
        >
          {t('why_iteraqua.title', lang)}
        </h2>
        <p class="mt-4 text-lg text-slate-300 max-w-xl text-pretty leading-relaxed">
          {t('why_iteraqua.subtitle', lang)}
        </p>

        <div class="mt-8 flex items-center gap-4">
          <div class="h-px flex-1 bg-gradient-to-r from-aqua-500/40 to-transparent" aria-hidden="true"></div>
          <span class="text-aqua-400 text-xs font-bold uppercase tracking-widest">
            {t('why_iteraqua.since_badge', lang)}
          </span>
        </div>
      </div>

      <div class="space-y-6" role="list" aria-label={t('why_iteraqua.title', lang)}>
        {differentiators.map((item, index) => (
          <div
            class="animate-on-scroll flex gap-4 p-5 rounded-xl bg-navy-800/50 border border-navy-700/50 hover:border-aqua-500/30 hover:bg-navy-800/80 transition-all duration-300 group"
            role="listitem"
            style={`animation-delay: ${index * 0.08}s`}
          >
            <div class="flex-shrink-0 w-12 h-12 rounded-lg bg-aqua-500/10 border border-aqua-500/20 flex items-center justify-center group-hover:bg-aqua-500/20 transition-colors duration-300">
              <svg
                class="w-6 h-6 text-aqua-400"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
                aria-hidden="true"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="1.5"
                  d={iconPaths[item.icon]}
                />
              </svg>
            </div>
            <div class="min-w-0">
              <h3 class="text-base font-semibold text-white leading-snug">
                {t(item.titleKey, lang)}
              </h3>
              <p class="mt-1.5 text-sm text-slate-400 leading-relaxed">
                {t(item.descKey, lang)}
              </p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>
