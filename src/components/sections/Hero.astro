---
import type { Language } from '@/i18n/utils';
import { t, useTranslatedPath } from '@/i18n/utils';

interface Props {
  lang: Language;
}

const { lang } = Astro.props;
const translatePath = useTranslatedPath(lang);
---

<section class="relative overflow-hidden gradient-navy min-h-[85vh] flex items-center" aria-label="Hero">
  <!-- Background image + overlay -->
  <div class="absolute inset-0">
    <div class="absolute inset-0 bg-gradient-to-b from-navy-950/50 to-navy-950/90 z-10"></div>
    <div class="absolute inset-0 bg-[url('/images/hero-maritime.jpg')] bg-cover bg-center bg-no-repeat"></div>
  </div>

  <!-- Wave layer (FIXED: no background-repeat anymore) -->
  <div class="absolute inset-0 overflow-hidden z-10 opacity-[0.03] pointer-events-none">
    <img
      src="/images/pattern-waves.svg"
      class="w-full h-full object-cover"
      alt=""
      aria-hidden="true"
    />
  </div>

  <!-- Content -->
  <div class="container-default relative z-20 py-20 md:py-28 lg:py-36">
    <div class="max-w-3xl">
      <div class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full bg-aqua-500/10 border border-aqua-500/20 text-aqua-400 text-sm font-medium mb-6 animate-fade-in">
        <span class="w-2 h-2 rounded-full bg-aqua-400 animate-pulse"></span>
        {t('hero.badge', lang)}
      </div>

      <h1 class="text-4xl md:text-5xl lg:text-6xl xl:text-7xl font-bold text-white leading-tight text-balance animate-slide-up">
        {t('hero.headline', lang)}
      </h1>

      <p class="mt-6 text-lg md:text-xl text-slate-300 max-w-2xl text-pretty animate-slide-up" style="animation-delay: 0.1s">
        {t('hero.subtitle', lang)}
      </p>

      <div class="mt-8 flex flex-col sm:flex-row gap-4 animate-slide-up" style="animation-delay: 0.2s">
        <a href={translatePath('services')} class="btn-secondary text-base px-8 py-4">
          {t('hero.cta_services', lang)}
          <svg class="w-5 h-5 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
          </svg>
        </a>

        <a href={translatePath('contact')} class="btn-outline-light text-base px-8 py-4">
          {t('hero.cta_contact', lang)}
        </a>
      </div>
    </div>
  </div>

  <!-- Bottom fade -->
  <div class="absolute bottom-0 left-0 right-0 h-24 bg-gradient-to-t from-white to-transparent z-20"></div>
</section>