---
import type { Language } from '@/i18n/utils';
import { t, useTranslatedPath, getRouteFromUrl } from '@/i18n/utils';
import LanguageSwitcher from './LanguageSwitcher.astro';
import MobileMenu from './MobileMenu.astro';

interface Props {
  lang: Language;
  path: string;
}

const { lang, path } = Astro.props;
const translatePath = useTranslatedPath(lang);

const services = [
  { label: t('nav.services_port_maintenance', lang), href: translatePath('/servicios/mantenimiento-portuario') },
  { label: t('nav.services_underwater_works', lang), href: translatePath('/servicios/trabajos-subacuaticos') },
  { label: t('nav.services_maritime_engineering', lang), href: translatePath('/servicios/ingenieria-maritima') },
  { label: t('nav.services_coastal_engineering', lang), href: translatePath('/servicios/ingenieria-costera') },
  { label: t('nav.services_hydraulic_infrastructure', lang), href: translatePath('/servicios/actuaciones-hidraulicas') },
  { label: t('nav.services_underwater_inspections', lang), href: translatePath('/servicios/inspecciones-subacuaticas') },
];

const navItems = [
  { label: t('nav.home', lang), href: translatePath('/') },
  { label: t('nav.company', lang), href: translatePath('/empresa') },
  { label: t('nav.services', lang), href: translatePath('/servicios'), children: services },
  { label: t('nav.projects', lang), href: translatePath('/proyectos') },
  { label: t('nav.blog', lang), href: translatePath('/blog') },
  { label: t('nav.certifications', lang), href: translatePath('/certificaciones') },
  { label: t('nav.contact', lang), href: translatePath('/contacto') },
];
---

<header class="sticky top-0 z-50 bg-white/95 backdrop-blur-sm border-b border-slate-200" role="banner">
  <div class="container-default">
    <div class="flex items-center justify-between h-16 lg:h-20">
      <a href={translatePath('/')} class="flex items-center gap-2 group" aria-label="Iteraqua - Inicio">
        <div class="flex items-center">
          <svg width="140" height="36" viewBox="0 0 140 36" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true" class="h-8 lg:h-9">
            <text x="0" y="26" font-family="Inter, sans-serif" font-weight="800" font-size="24" fill="#0f1f3d">Iter</text>
            <text x="56" y="26" font-family="Inter, sans-serif" font-weight="800" font-size="24" fill="#00d4cc">aqua</text>
          </svg>
        </div>
      </a>

      <nav class="hidden lg:flex items-center gap-1" aria-label="Main navigation">
        {navItems.map((item) => (
          <div class="relative group">
            <a
              href={item.href}
              class="px-3 py-2 text-sm font-medium text-slate-700 hover:text-navy-900 rounded-md transition-colors"
            >
              {item.label}
              {item.children && (
                <svg class="inline-block w-4 h-4 ml-1" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
                </svg>
              )}
            </a>
            {item.children && (
              <div class="absolute left-0 top-full pt-2 opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-200 z-50">
                <div class="bg-white rounded-lg shadow-lg border border-slate-200 py-2 min-w-[260px]">
                  {item.children.map((child) => (
                    <a
                      href={child.href}
                      class="block px-4 py-2 text-sm text-slate-700 hover:text-navy-900 hover:bg-slate-50 transition-colors"
                    >
                      {child.label}
                    </a>
                  ))}
                </div>
              </div>
            )}
          </div>
        ))}
      </nav>

      <div class="flex items-center gap-3">
        <LanguageSwitcher lang={lang} path={path} />
        <a
          href={translatePath('/contacto')}
          class="hidden lg:inline-flex btn-primary text-sm"
        >
          {t('hero.cta_contact', lang)}
        </a>
        <MobileMenu lang={lang} navItems={navItems} />
      </div>
    </div>
  </div>
</header>
