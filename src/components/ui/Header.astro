---
import type { Language } from '@/i18n/utils';
import { t, useTranslatedPath } from '@/i18n/utils';
import LanguageSwitcher from './LanguageSwitcher.astro';
import MobileMenu from './MobileMenu.astro';

interface Props {
  lang: Language;
  path: string;
}

const { lang, path } = Astro.props;
const translatePath = useTranslatedPath(lang);

const services = [
  { label: t('nav.services_port_maintenance', lang), href: translatePath('services.portMaintenance') },
  { label: t('nav.services_underwater_works', lang), href: translatePath('services.underwaterWorks') },
  { label: t('nav.services_maritime_engineering', lang), href: translatePath('services.maritimeEngineering') },
  { label: t('nav.services_coastal_engineering', lang), href: translatePath('services.coastalEngineering') },
  { label: t('nav.services_hydraulic_infrastructure', lang), href: translatePath('services.hydraulicInfrastructure') },
  { label: t('nav.services_underwater_inspections', lang), href: translatePath('services.underwaterInspections') },
];

const servicesMenuId = 'desktop-services-menu';

const navItems = [
  { label: t('nav.home', lang), href: translatePath('home') },
  { label: t('nav.company', lang), href: translatePath('company') },
  { label: t('nav.services', lang), href: translatePath('services'), children: services },
  { label: t('nav.projects', lang), href: translatePath('projects') },
  { label: t('nav.blog', lang), href: translatePath('blog') },
  { label: t('nav.contact', lang), href: translatePath('contact') },
];
---

<header class="sticky top-0 z-50 bg-white/95 backdrop-blur-sm border-b border-slate-200" role="banner">
  <div class="container-default">
    <div class="flex items-center justify-between h-16 lg:h-20">
      <a href={translatePath('home')} class="flex items-center gap-2 group" aria-label="Iteraqua - Inicio">
        <div class="flex items-center">
          <!--svg width="140" height="36" viewBox="0 0 140 36" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true" class="h-8 lg:h-9">
            <text x="0" y="26" font-family="Inter, sans-serif" font-weight="800" font-size="24" fill="#0f1f3d">Iter</text>
            <text x="56" y="26" font-family="Inter, sans-serif" font-weight="800" font-size="24" fill="#00d4cc">aqua</text>
          </svg-->
          <img src={import.meta.env.BASE_URL + "images/logo.png"} />
        </div>
      </a>

      <nav class="hidden lg:flex items-center gap-1" aria-label="Main navigation">
        {navItems.map((item) => (
          <div class="relative group" data-header-dropdown={item.children ? true : undefined}>
            <a
              href={item.href}
              class="px-3 py-2 text-sm font-medium text-slate-700 hover:text-navy-900 focus:text-navy-900 rounded-md transition-colors"
              aria-haspopup={item.children ? 'true' : undefined}
              aria-expanded={item.children ? 'false' : undefined}
              aria-controls={item.children ? servicesMenuId : undefined}
              data-header-dropdown-trigger={item.children ? true : undefined}
            >
              {item.label}
              {item.children && (
                <svg class="inline-block w-4 h-4 ml-1" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
                </svg>
              )}
            </a>
            {item.children && (
              <div
                id={servicesMenuId}
                class="absolute left-0 top-full pt-2 opacity-0 invisible group-hover:opacity-100 group-hover:visible group-focus-within:opacity-100 group-focus-within:visible transition-all duration-200 z-50"
              >
                <div class="bg-white rounded-lg shadow-lg border border-slate-200 py-2 min-w-[260px]" role="menu" aria-label={item.label}>
                  {item.children.map((child) => (
                    <a
                      href={child.href}
                      class="block px-4 py-2 text-sm text-slate-700 hover:text-navy-900 hover:bg-slate-50 focus:text-navy-900 focus:bg-slate-50 transition-colors"
                      role="menuitem"
                    >
                      {child.label}
                    </a>
                  ))}
                </div>
              </div>
            )}
          </div>
        ))}
      </nav>

      <div class="flex items-center gap-3">
        <LanguageSwitcher lang={lang} path={path} />
        <a
          href={translatePath('contact')}
          class="hidden lg:inline-flex btn-primary text-sm"
        >
          {t('hero.cta_contact', lang)}
        </a>
        <MobileMenu lang={lang} navItems={navItems} />
      </div>
    </div>
  </div>
</header>


<script>
  const headerDropdowns = document.querySelectorAll('[data-header-dropdown]');

  headerDropdowns.forEach((dropdown) => {
    const trigger = dropdown.querySelector('[data-header-dropdown-trigger]');

    if (!(trigger instanceof HTMLElement)) return;

    const setExpanded = (isExpanded: boolean) => {
      trigger.setAttribute('aria-expanded', String(isExpanded));
    };

    dropdown.addEventListener('mouseenter', () => setExpanded(true));
    dropdown.addEventListener('mouseleave', () => setExpanded(false));
    dropdown.addEventListener('focusin', () => setExpanded(true));
    dropdown.addEventListener('focusout', (event) => {
      const nextTarget = event.relatedTarget;
      if (!(nextTarget instanceof Node) || !dropdown.contains(nextTarget)) {
        setExpanded(false);
      }
    });
  });
</script>
