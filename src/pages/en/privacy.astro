---
import BaseLayout from '@/layouts/BaseLayout.astro';
import type { Language } from '@/i18n/utils';
import { t, useTranslatedPath } from '@/i18n/utils';

const lang: Language = 'en';
const translatePath = useTranslatedPath(lang);

const structuredData = [
  {
    "@context": "https://schema.org",
    "@type": "Article",
    "name": t('legal.privacy_title', lang),
    "articleSection": "Legal"
  }
];
---

<PageLayout
  title={t('legal.privacy_title', lang)}
  description="Iteraqua Privacy Policy"
  lang={lang}
  path="/privacy"
  heroTitle={t('legal.privacy_title', lang)}
  heroSubtitle="Information about the processing of personal data"
  breadcrumbs={[
    { label: t('nav.home', lang), href: translatePath('/') },
    { label: t('legal.privacy_title', lang), href: translatePath('/privacy') },
  ]}
  structuredData={structuredData}
>
  <section class="section-padding bg-white">
    <div class="container-default">
      <div class="prose max-w-3xl mx-auto animate-on-scroll">
        <h2>{t('legal.privacy.sections.0', lang)}</h2>
        <p class="text-slate-600">Information about the data controller for your personal data.</p>
        
        <h2 class="mt-8">{t('legal.privacy.sections.1', lang)}</h2>
        <p class="text-slate-600">Description of the personal data we collect and how we use it.</p>
        
        <h2 class="mt-8">{t('legal.privacy.sections.2', lang)}</h2>
        <p class="text-slate-600">Purpose of processing your personal data.</p>
        
        <h2 class="mt-8">{t('legal.privacy.sections.3', lang)}</h2>
        <p class="text-slate-600">Legal basis for processing your data.</p>
        
        <h2 class="mt-8">{t('legal.privacy.sections.4', lang)}</h2>
        <p class="text-slate-600">Recipients of your personal data.</p>
        
        <h2 class="mt-8">{t('legal.privacy.sections.5', lang)}</h2>
        <p class="text-slate-600">Your rights regarding your personal data.</p>
        
        <h2 class="mt-8">{t('legal.privacy.sections.6', lang)}</h2>
        <p class="text-slate-600">Retention of your personal data.</p>
        
        <h2 class="mt-8">{t('legal.privacy.sections.7', lang)}</h2>
        <p class="text-slate-600">Security measures applied.</p>
      </div>
    </div>
  </section>
</PageLayout>