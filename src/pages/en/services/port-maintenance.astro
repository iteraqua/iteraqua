---
import PageLayout from '@/layouts/PageLayout.astro';
import type { Language } from '@/i18n/utils';
import { t, useTranslatedPath } from '@/i18n/utils';
import { ui } from '@/i18n/ui';
import { generateServiceSchema, generateFAQSchema } from '@/utils/seo';

const lang: Language = 'en';
const translatePath = useTranslatedPath(lang);
const serviceKey = 'port_maintenance';
const service = ui[lang].services[serviceKey] as any;
const capabilities: string[] = service.capabilities;
const process: { step: number; title: string; description: string }[] = service.process;
const faqs: { q: string; a: string }[] = service.faqs;

const structuredData = [
  generateServiceSchema({
    name: service.title,
    description: service.shortDescription,
    url: `https://iteraqua.com/en/services/port-maintenance`,
    areaServed: 'Spain',
    provider: 'Iteraqua',
  }),
  generateFAQSchema(faqs.map(f => ({ question: f.q, answer: f.a }))),
];
---

<PageLayout
  title={service.title}
  description={service.shortDescription}
  lang={lang}
  path="/services/port-maintenance"
  heroTitle={service.title}
  heroSubtitle={service.shortDescription}
  breadcrumbs={[
    { label: t('nav.home', lang), href: translatePath('/') },
    { label: t('nav.services', lang), href: translatePath('/servicios') },
    { label: service.title, href: translatePath('/services/port-maintenance') },
  ]}
  structuredData={structuredData}
>
  <section class="section-padding bg-white">
    <div class="container-default">
      <div class="max-w-3xl mx-auto animate-on-scroll">
        <h2 class="section-heading text-navy-900 mb-6">{service.title}</h2>
        <p class="text-lg text-slate-600 leading-relaxed">{service.description}</p>
      </div>
    </div>
  </section>

  <section class="section-padding bg-slate-50">
    <div class="container-default">
      <h2 class="section-heading text-navy-900 mb-12 animate-on-scroll">{t('common.learn_more', lang)}</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        {capabilities.map((cap) => (
          <div class="flex items-start gap-3 bg-white rounded-lg p-6 shadow-sm border border-slate-200 animate-on-scroll">
            <span class="text-aqua-500 mt-1 flex-shrink-0">✓</span>
            <span class="text-slate-700">{cap}</span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="section-padding bg-white">
    <div class="container-default">
      <h2 class="section-heading text-navy-900 mb-12 animate-on-scroll">Work process</h2>
      <div class="max-w-3xl mx-auto space-y-8">
        {process.map((step) => (
          <div class="flex items-start gap-6 animate-on-scroll">
            <div class="flex-shrink-0 w-12 h-12 rounded-full bg-navy-900 text-white flex items-center justify-center font-bold text-lg">
              {step.step}
            </div>
            <div>
              <h3 class="text-lg font-bold text-navy-900 mb-2">{step.title}</h3>
              <p class="text-slate-600 leading-relaxed">{step.description}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="section-padding bg-slate-50">
    <div class="container-default">
      <h2 class="section-heading text-navy-900 mb-12 animate-on-scroll">Frequently asked questions</h2>
      <div class="max-w-3xl mx-auto space-y-4">
        {faqs.map((faq) => (
          <details class="bg-white rounded-lg border border-slate-200 overflow-hidden animate-on-scroll group">
            <summary class="px-6 py-4 cursor-pointer font-semibold text-navy-900 hover:bg-slate-50 transition-colors flex items-center justify-between">
              <span>{faq.q}</span>
              <span class="text-aqua-500 transition-transform group-open:rotate-180">▼</span>
            </summary>
            <div class="px-6 pb-4 text-slate-600 leading-relaxed">
              {faq.a}
            </div>
          </details>
        ))}
      </div>
    </div>
  </section>

  <section class="gradient-navy section-padding">
    <div class="container-default text-center">
      <h2 class="text-2xl md:text-3xl font-bold text-white mb-4 animate-on-scroll">{t('cta.title', lang)}</h2>
      <p class="text-slate-300 mb-8 max-w-2xl mx-auto animate-on-scroll">{t('cta.subtitle', lang)}</p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center animate-on-scroll">
        <a href={translatePath('/contacto')} class="btn-secondary">{t('cta.cta_consultation', lang)}</a>
        <a href="https://wa.me/34972000000" target="_blank" rel="noopener noreferrer" class="btn-outline-light">{t('cta.cta_whatsapp', lang)}</a>
      </div>
    </div>
  </section>
</PageLayout>