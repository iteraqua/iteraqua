---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Hero from '../../../../components/sections/Hero.astro';
import TrustBar from '../../../../components/sections/TrustBar.astro';
import ServicesOverview from '../../../../components/sections/ServicesOverview.astro';
import FeaturedProjects from '../../../../components/sections/FeaturedProjects.astro';
import WhyIteraqua from '../../../../components/sections/WhyIteraqua.astro';
import CtaSection from '../../../../components/sections/CtaSection.astro';
import type { Language } from '@/i18n/utils';

const lang: Language = 'en';
---

<BaseLayout
  title="Maritime engineering and underwater operations"
  description="Iteraqua: over 25 years designing, building and maintaining port and coastal infrastructure. Precision maritime engineering and professional underwater operations."
  lang={lang}
  path="/en/"
  image="/images/og-default.jpg"
>
  <Hero lang={lang} />
  <TrustBar lang={lang} />
  <ServicesOverview lang={lang} />
  <WhyIteraqua lang={lang} />
  <FeaturedProjects lang={lang} />
  <CtaSection lang={lang} />
</BaseLayout>