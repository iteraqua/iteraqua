---
import PageLayout from '@/layouts/PageLayout.astro';
import type { Language } from '@/i18n/utils';
import { t, useTranslatedPath } from '@/i18n/utils';
import { ui } from '@/i18n/ui';
import { getCollection } from 'astro:content';

const lang: Language = 'es';
const translatePath = useTranslatedPath(lang);
const serviceData = ui[lang];

const allServices = await getCollection('services', ({ data }) => data.published);
allServices.sort((a, b) => a.data.order - b.data.order);

const serviceIcons: Record<string, string> = {
  port_maintenance: '⚓',
  underwater_works: '🤿',
  maritime_engineering: '🧭',
  coastal_engineering: '🏖️',
  hydraulic_infrastructure: '💧',
  underwater_inspections: '🔍',
};

const structuredData = [
  {
    "@context": "https://schema.org",
    "@type": "CollectionPage",
    "name": t('nav.services', lang),
    "description": t('services_overview.subtitle', lang),
    "url": `https://iteraqua.com/servicios`,
  },
];
---

<PageLayout
  title={t('nav.services', lang)}
  description={t('services_overview.subtitle', lang)}
  lang={lang}
  path="/servicios"
  heroTitle={t('nav.services', lang)}
  heroSubtitle={t('services_overview.subtitle', lang)}
  breadcrumbs={[
    { label: t('nav.home', lang), href: translatePath('home') },
    { label: t('nav.services', lang), href: translatePath('services') },
  ]}
  structuredData={structuredData}
>
  <section class="section-padding bg-white">
    <div class="container-default">
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        {allServices.map((service) => {
          const key = service.data.id as string;
          const serviceInfo = serviceData.services[key];
          return (
            <a href={translatePath(({ port_maintenance: 'services.portMaintenance', underwater_works: 'services.underwaterWorks', maritime_engineering: 'services.maritimeEngineering', coastal_engineering: 'services.coastalEngineering', hydraulic_infrastructure: 'services.hydraulicInfrastructure', underwater_inspections: 'services.underwaterInspections' } as const)[service.data.id as 'port_maintenance' | 'underwater_works' | 'maritime_engineering' | 'coastal_engineering' | 'hydraulic_infrastructure' | 'underwater_inspections'])} class="card group p-8 block animate-on-scroll">
              <span class="text-4xl mb-4 block">{serviceIcons[key] || '⚙️'}</span>
              <h3 class="text-xl font-bold text-navy-900 mb-2 group-hover:text-aqua-600 transition-colors">
                {service.data.title[lang]}
              </h3>
              <p class="text-slate-600 text-sm leading-relaxed mb-4">
                {service.data.shortDescription[lang]}
              </p>
              <span class="text-aqua-600 font-semibold text-sm inline-flex items-center gap-1 group-hover:gap-2 transition-all">
                {t('common.learn_more', lang)} →
              </span>
            </a>
          );
        })}
      </div>
    </div>
  </section>

  <section class="gradient-navy section-padding">
    <div class="container-default text-center">
      <h2 class="text-2xl md:text-3xl font-bold text-white mb-4 animate-on-scroll">{t('cta.title', lang)}</h2>
      <p class="text-slate-300 mb-8 max-w-2xl mx-auto animate-on-scroll">{t('cta.subtitle', lang)}</p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center animate-on-scroll">
        <a href={translatePath('contact')} class="btn-secondary">{t('cta.cta_consultation', lang)}</a>
        <a href="https://wa.me/34972000000" target="_blank" rel="noopener noreferrer" class="btn-outline-light">{t('cta.cta_whatsapp', lang)}</a>
      </div>
    </div>
  </section>
</PageLayout>
