---
import PageLayout from '@/layouts/PageLayout.astro';
import type { Language } from '@/i18n/utils';
import { t, useTranslatedPath } from '@/i18n/utils';

const lang: Language = 'es';
const translatePath = useTranslatedPath(lang);
---

<PageLayout
  title={t('certifications_page.title', lang)}
  description={t('certifications_page.subtitle', lang)}
  lang={lang}
  path="/certificaciones"
  heroTitle={t('certifications_page.title', lang)}
  heroSubtitle={t('certifications_page.subtitle', lang)}
  breadcrumbs={[
    { label: t('nav.home', lang), href: translatePath('home') },
    { label: t('nav.certifications', lang), href: translatePath('certifications') },
  ]}
>
  <section class="section-padding bg-white">
    <div class="container-default">
      <div class="max-w-4xl mx-auto">
        <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
          <div class="card p-6">
            <h3 class="text-xl font-bold text-navy-900 mb-4">{t('certifications_page.quality_title', lang)}</h3>
            <p class="text-slate-600">{t('certifications_page.quality_text', lang)}</p>
          </div>
          
          <div class="card p-6">
            <h3 class="text-xl font-bold text-navy-900 mb-4">{t('certifications_page.safety_title', lang)}</h3>
            <p class="text-slate-600">{t('certifications_page.safety_text', lang)}</p>
          </div>
          
          <div class="card p-6">
            <h3 class="text-xl font-bold text-navy-900 mb-4">{t('certifications_page.environmental_title', lang)}</h3>
            <p class="text-slate-600">{t('certifications_page.environmental_text', lang)}</p>
            <div class="mt-4">
              <h4 class="font-semibold text-slate-800">{t('certifications_page.safety_standards_label', lang)}</h4>
              <ul class="mt-2 space-y-1">
                {t('certifications_page.standards_list', lang).map((standard, index) => (
                  <li key={index} class="text-slate-600 text-sm">
                    <span class="font-medium">{standard.name}:</span> {standard.description}
                  </li>
                ))}
              </ul>
            </div>
          </div>
          
          <div class="card p-6">
            <h3 class="text-xl font-bold text-navy-900 mb-4">{t('certifications_page.diving_title', lang)}</h3>
            <p class="text-slate-600">{t('certifications_page.diving_text', lang)}</p>
            <div class="mt-4">
              <h4 class="font-semibold text-slate-800">{t('certifications_page.certifications_label', lang)}</h4>
              <ul class="mt-2 space-y-1">
                {t('certifications_page.certifications_list', lang).map((cert, index) => (
                  <li key={index} class="text-slate-600 text-sm">
                    <span class="font-medium">{cert.name}:</span> {cert.description}
                  </li>
                ))}
              </ul>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>
</PageLayout>