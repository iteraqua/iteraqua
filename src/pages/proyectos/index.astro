---
import PageLayout from '@/layouts/PageLayout.astro';
import { getCollection } from 'astro:content';
import type { Language } from '@/i18n/utils';
import { t, useTranslatedPath } from '@/i18n/utils';
import { ui } from '@/i18n/ui';

const lang: Language = 'es';
const translatePath = useTranslatedPath(lang);
const allProjects = await getCollection('projects', ({ data }) => data.published);

const categories = [
  { key: 'all', label: t('projects.filter_all', lang) },
  { key: 'port_maintenance', label: ui[lang].projects?.filter_port_maintenance as string || 'Mantenimiento Portuario' },
  { key: 'underwater_works', label: ui[lang].projects?.filter_underwater_works as string || 'Trabajos Subacuáticos' },
  { key: 'maritime_engineering', label: ui[lang].projects?.filter_maritime_engineering as string || 'Ingeniería Marítima' },
  { key: 'coastal_engineering', label: ui[lang].projects?.filter_coastal_engineering as string || 'Ingeniería Costera' },
  { key: 'hydraulic_infrastructure', label: ui[lang].projects?.filter_hydraulic_infrastructure as string || 'Actuaciones Hidráulicas' },
  { key: 'underwater_inspections', label: ui[lang].projects?.filter_underwater_inspections as string || 'Inspecciones Subacuáticas' },
];
---

<PageLayout
  title={t('projects.all_projects', lang)}
  description="Proyectos de ingeniería marítima, costera e hidráulica ejecutados por Iteraqua."
  lang={lang}
  path="/proyectos"
  heroTitle={t('projects.all_projects', lang)}
  heroSubtitle="Soluciones reales para desafíos complejos en entornos marítimos e hidráulicos."
  breadcrumbs={[
    { label: t('nav.home', lang), href: translatePath('/') },
    { label: t('nav.projects', lang), href: translatePath('/proyectos') },
  ]}
>
  <section class="section-padding bg-white">
    <div class="container-default">
      <div class="flex flex-wrap gap-3 mb-12">
        {categories.map((cat) => (
          <button
            class="px-4 py-2 rounded-full text-sm font-medium border border-slate-200 text-slate-600 hover:border-aqua-500 hover:text-aqua-600 transition-colors"
            data-filter={cat.key}
          >
            {cat.label}
          </button>
        ))}
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        {allProjects.map((project) => (
          <article class="card animate-on-scroll" data-category={project.data.category}>
            <div class="aspect-video bg-slate-200 rounded-t-lg overflow-hidden mb-0">
              <img
                src={project.data.image}
                alt={project.data.title[lang] || project.data.title.es}
                class="w-full h-full object-cover"
                loading="lazy"
              />
            </div>
            <div class="p-6">
              <span class="text-xs font-semibold text-aqua-600 uppercase tracking-wide">
                {categories.find(c => c.key === project.data.category)?.label}
              </span>
              <h3 class="text-lg font-bold text-navy-900 mt-2 mb-2">
                {project.data.title[lang] || project.data.title.es}
              </h3>
              <p class="text-slate-600 text-sm mb-4">
                {project.data.description[lang] || project.data.description.es}
              </p>
              <div class="flex items-center gap-4 text-xs text-slate-500 mb-4">
                <span>{project.data.location}</span>
                <span>{project.data.year}</span>
              </div>
              <a href={translatePath(`/proyectos/${project.slug}`)} class="text-aqua-600 hover:text-aqua-700 font-medium text-sm">
                {t('projects.view_project', lang)} →
              </a>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>
</PageLayout>