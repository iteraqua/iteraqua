---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import type { Language } from '@/i18n/utils';
import { t, useTranslatedPath } from '@/i18n/utils';

const lang: Language = 'ca';
const translatePath = useTranslatedPath(lang);
const allPosts = await getCollection('blog', ({ data }) => data.published);
allPosts.sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime());
---

<BaseLayout
  title={t('blog_page.title', lang)}
  description={t('blog_page.subtitle', lang)}
  lang={lang}
  path="/ca/blog"
>
  <div class="container-default section-padding">
    <div class="max-w-4xl mx-auto">
      <h1 class="text-3xl font-bold text-navy-900 mb-4">{t('blog_page.title', lang)}</h1>
      <p class="text-slate-600 mb-12">{t('blog_page.subtitle', lang)}</p>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {allPosts.map((post) => (
          <article class="card">
            <div class="p-6">
              <h3 class="text-xl font-bold text-navy-900 mb-2">
                {post.data.title[lang] || post.data.title.ca}
              </h3>
              <p class="text-slate-600 text-sm mb-4">
                {post.data.description[lang] || post.data.description.ca}
              </p>
              <a href={`/ca/blog/${post.slug}`} class="text-aqua-600 hover:text-aqua-700 font-medium text-sm">
                {t('common.read_more', lang)}
              </a>
            </div>
          </article>
        ))}
      </div>
    </div>
  </div>
</BaseLayout>