---
import PageLayout from '@/layouts/PageLayout.astro';
import type { Language } from '@/i18n/utils';
import { t, useTranslatedPath } from '@/i18n/utils';
import { ui } from '@/i18n/ui';
import { getCollection } from 'astro:content';

const lang: Language = 'ca';
const translatePath = useTranslatedPath(lang);
const projectData = ui[lang].projects as any;

const allProjects = await getCollection('projects', ({ data }) => data.published);
allProjects.sort((a, b) => b.data.year - a.data.year);

const categories = [
  { key: 'all', label: projectData.filter_all },
  { key: 'port_maintenance', label: projectData.filter_port_maintenance },
  { key: 'underwater_works', label: projectData.filter_underwater_works },
  { key: 'maritime_engineering', label: projectData.filter_maritime_engineering },
  { key: 'coastal_engineering', label: projectData.filter_coastal_engineering },
  { key: 'hydraulic_infrastructure', label: projectData.filter_hydraulic_infrastructure },
  { key: 'underwater_inspections', label: projectData.filter_underwater_inspections },
];

const structuredData = [
  {
    "@context": "https://schema.org",
    "@type": "CollectionPage",
    "name": t('nav.projects', lang),
    "description": t('featured_projects.subtitle', lang),
    "url": "https://iteraqua.com/ca/projectes",
  },
];
---

<PageLayout
  title={t('nav.projects', lang)}
  description={t('featured_projects.subtitle', lang)}
  lang={lang}
  path="/projectes"
  heroTitle={t('nav.projects', lang)}
  heroSubtitle={t('featured_projects.subtitle', lang)}
  breadcrumbs={[
    { label: t('nav.home', lang), href: translatePath('home') },
    { label: t('nav.projects', lang), href: translatePath('projects') },
  ]}
  structuredData={structuredData}
>
  <section class="section-padding bg-white">
    <div class="container-default">
      <div class="flex flex-wrap gap-3 mb-10 justify-center animate-on-scroll" id="project-filters">
        {categories.map((cat) => (
          <button
            class={`px-4 py-2 rounded-full text-sm font-semibold transition-colors duration-200 ${cat.key === 'all' ? 'bg-navy-900 text-white' : 'bg-slate-100 text-slate-600 hover:bg-slate-200'}`}
            data-filter={cat.key}
          >
            {cat.label}
          </button>
        ))}
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8" id="projects-grid">
        {allProjects.map((project) => (
          <a
            href={translatePath('projectDetail', { slug: project.id })}
            class="card group block animate-on-scroll"
            data-category={project.data.category}
          >
            <div class="aspect-video bg-slate-200 overflow-hidden">
              <img
                src={project.data.image}
                alt={project.data.title[lang]}
                class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300"
                loading="lazy"
              />
            </div>
            <div class="p-6">
              <span class="text-xs font-semibold text-aqua-600 uppercase tracking-wider">
                {projectData[`filter_${project.data.category}`] || project.data.category}
              </span>
              <h3 class="text-lg font-bold text-navy-900 mt-2 mb-2 group-hover:text-aqua-600 transition-colors">
                {project.data.title[lang]}
              </h3>
              <p class="text-sm text-slate-600 mb-4 line-clamp-3">{project.data.description[lang]}</p>
              <div class="flex items-center gap-4 text-xs text-slate-500">
                <span class="flex items-center gap-1">📍 {project.data.location}</span>
                <span class="flex items-center gap-1">📅 {project.data.year}</span>
              </div>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <section class="gradient-navy section-padding">
    <div class="container-default text-center">
      <h2 class="text-2xl md:text-3xl font-bold text-white mb-4 animate-on-scroll">{t('cta.title', lang)}</h2>
      <p class="text-slate-300 mb-8 max-w-2xl mx-auto animate-on-scroll">{t('cta.subtitle', lang)}</p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center animate-on-scroll">
        <a href={translatePath('contact')} class="btn-secondary">{t('cta.cta_consultation', lang)}</a>
        <a href="https://wa.me/34972000000" target="_blank" rel="noopener noreferrer" class="btn-outline-light">{t('cta.cta_whatsapp', lang)}</a>
      </div>
    </div>
  </section>
</PageLayout>

<script>
  document.addEventListener('astro:page-load', () => {
    const filterContainer = document.getElementById('project-filters');
    const grid = document.getElementById('projects-grid');
    if (!filterContainer || !grid) return;

    const buttons = filterContainer.querySelectorAll('button');
    buttons.forEach((btn) => {
      btn.addEventListener('click', () => {
        const filter = btn.getAttribute('data-filter');
        buttons.forEach((b) => {
          b.classList.remove('bg-navy-900', 'text-white');
          b.classList.add('bg-slate-100', 'text-slate-600');
        });
        btn.classList.remove('bg-slate-100', 'text-slate-600');
        btn.classList.add('bg-navy-900', 'text-white');

        const cards = grid.querySelectorAll('[data-category]');
        cards.forEach((card) => {
          const el = card as HTMLElement;
          if (filter === 'all' || card.getAttribute('data-category') === filter) {
            el.style.display = '';
          } else {
            el.style.display = 'none';
          }
        });
      });
    });
  });
</script>
