---
import PageLayout from '@/layouts/PageLayout.astro';
import type { Language } from '@/i18n/utils';
import { t, useTranslatedPath } from '@/i18n/utils';

const lang: Language = 'ca';
const translatePath = useTranslatedPath(lang);

const structuredData = [
  {
    "@context": "https://schema.org",
    "@type": "ContactPage",
    "name": t('contact.title', lang),
    "description": t('contact.subtitle', lang),
  }
];
---

<PageLayout
  title={t('contact.title', lang)}
  description={t('contact.subtitle', lang)}
  lang={lang}
  path="/contacte"
  heroTitle={t('contact.title', lang)}
  heroSubtitle={t('contact.subtitle', lang)}
  breadcrumbs={[
    { label: t('nav.home', lang), href: translatePath('home') },
    { label: t('nav.contact', lang), href: translatePath('contact') },
  ]}
  structuredData={structuredData}
>
  <section class="section-padding bg-white">
    <div class="container-default">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 animate-on-scroll">
        <div>
          <h2 class="text-2xl font-bold text-navy-900 mb-6">{t('contact.title', lang)}</h2>

          <form class="space-y-6">
            <div>
              <label for="name" class="block text-sm font-medium text-slate-700 mb-1">{t('contact.form_name', lang)}</label>
              <input
                type="text"
                id="name"
                name="name"
                class="w-full px-3 py-2 border border-slate-300 rounded-md shadow-sm focus:outline-none focus:ring-aqua-500 focus:border-aqua-500"
              />
            </div>

            <div>
              <label for="email" class="block text-sm font-medium text-slate-700 mb-1">{t('contact.form_email', lang)}</label>
              <input
                type="email"
                id="email"
                name="email"
                class="w-full px-3 py-2 border border-slate-300 rounded-md shadow-sm focus:outline-none focus:ring-aqua-500 focus:border-aqua-500"
              />
            </div>

            <div>
              <label for="phone" class="block text-sm font-medium text-slate-700 mb-1">{t('contact.form_phone', lang)}</label>
              <input
                type="tel"
                id="phone"
                name="phone"
                class="w-full px-3 py-2 border border-slate-300 rounded-md shadow-sm focus:outline-none focus:ring-aqua-500 focus:border-aqua-500"
              />
            </div>

            <div>
              <label for="service" class="block text-sm font-medium text-slate-700 mb-1">{t('contact.form_service', lang)}</label>
              <select
                id="service"
                name="service"
                class="w-full px-3 py-2 border border-slate-300 rounded-md shadow-sm focus:outline-none focus:ring-aqua-500 focus:border-aqua-500"
              >
                <option value="">{t('contact.form_service_placeholder', lang)}</option>
                <option value="port_maintenance">{t('nav.services_port_maintenance', lang)}</option>
                <option value="underwater_works">{t('nav.services_underwater_works', lang)}</option>
                <option value="maritime_engineering">{t('nav.services_maritime_engineering', lang)}</option>
                <option value="coastal_engineering">{t('nav.services_coastal_engineering', lang)}</option>
                <option value="hydraulic_infrastructure">{t('nav.services_hydraulic_infrastructure', lang)}</option>
                <option value="underwater_inspections">{t('nav.services_underwater_inspections', lang)}</option>
              </select>
            </div>

            <div>
              <label for="message" class="block text-sm font-medium text-slate-700 mb-1">{t('contact.form_message', lang)}</label>
              <textarea
                id="message"
                name="message"
                rows="4"
                class="w-full px-3 py-2 border border-slate-300 rounded-md shadow-sm focus:outline-none focus:ring-aqua-500 focus:border-aqua-500"
                placeholder={t('contact.form_message_placeholder', lang)}
              ></textarea>
            </div>

            <button
              type="submit"
              class="btn-primary"
            >
              {t('contact.form_submit', lang)}
            </button>
          </form>
        </div>

        <div>
          <div class="bg-slate-50 rounded-xl p-6">
            <h3 class="text-lg font-semibold text-navy-900 mb-4">{t('contact.map_label', lang)}</h3>
            <div class="bg-slate-200 border border-slate-300 rounded-lg h-64 flex items-center justify-center">
              <span class="text-slate-500">{t('contact.map_label', lang)}</span>
            </div>

            <div class="mt-8 space-y-4">
              <div class="flex items-center gap-3">
                <svg class="w-5 h-5 text-slate-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01-2.827 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10z" />
                </svg>
                <span class="text-slate-600">+34 972 000 000</span>
              </div>

              <div class="flex items-center gap-3">
                <svg class="w-5 h-5 text-slate-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10z" />
                </svg>
                <span class="text-slate-600">info@iteraqua.com</span>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>
</PageLayout>