---
import PageLayout from '@/layouts/PageLayout.astro';
import type { Language } from '@/i18n/utils';
import { t, useTranslatedPath } from '@/i18n/utils';
import { ui } from '@/i18n/ui';

const lang: Language = 'es';
const translatePath = useTranslatedPath(lang);
const serviceData = ui[lang];

const values = [
  { title: t('company_page.value_1_title', lang), text: t('company_page.value_1_text', lang) },
  { title: t('company_page.value_2_title', lang), text: t('company_page.value_2_text', lang) },
  { title: t('company_page.value_3_title', lang), text: t('company_page.value_3_text', lang) },
  { title: t('company_page.value_4_title', lang), text: t('company_page.value_4_text', lang) },
];

const icons = ['📐', '🛡️', '💡', '🌿'];

const structuredData = [
  {
    "@context": "https://schema.org",
    "@type": "AboutPage",
    "name": t('company_page.title', lang),
    "description": t('company_page.subtitle', lang),
    "url": `https://iteraqua.com/empresa`,
  },
];
---

<PageLayout
  title={t('company_page.title', lang)}
  description={t('company_page.subtitle', lang)}
  lang={lang}
  path="/empresa"
  heroTitle={t('company_page.title', lang)}
  heroSubtitle={t('company_page.subtitle', lang)}
  breadcrumbs={[
    { label: t('nav.home', lang), href: translatePath('home') },
    { label: t('nav.company', lang), href: translatePath('company') },
  ]}
  structuredData={structuredData}
>
  <section class="section-padding bg-white">
    <div class="container-default">
      <div class="max-w-3xl mx-auto animate-on-scroll">
        <h2 class="section-heading text-navy-900 mb-6">{t('company_page.mission_title', lang)}</h2>
        <p class="text-lg text-slate-600 leading-relaxed">{t('company_page.mission_text', lang)}</p>
      </div>
    </div>
  </section>

  <section class="section-padding bg-slate-50">
    <div class="container-default">
      <h2 class="section-heading text-navy-900 text-center mb-12 animate-on-scroll">{t('company_page.values_title', lang)}</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
        {values.map((value, index) => (
          <div class="bg-white rounded-xl p-8 shadow-sm border border-slate-200 animate-on-scroll">
            <span class="text-3xl mb-4 block">{icons[index]}</span>
            <h3 class="text-xl font-bold text-navy-900 mb-3">{value.title}</h3>
            <p class="text-slate-600 leading-relaxed">{value.text}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="section-padding bg-white">
    <div class="container-default text-center">
      <h2 class="section-heading text-navy-900 mb-4 animate-on-scroll">{serviceData.company.team_title}</h2>
      <p class="section-subheading mx-auto mb-12 animate-on-scroll">{serviceData.company.team_subtitle}</p>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-8">
        {[
          { role: 'Dirección de Ingeniería', icon: '👔' },
          { role: 'Operaciones Subacuáticas', icon: '🤿' },
          { role: 'Gestión de Proyectos', icon: '📋' },
        ].map((member) => (
          <div class="bg-slate-50 rounded-xl p-8 animate-on-scroll">
            <div class="w-24 h-24 bg-slate-200 rounded-full mx-auto mb-4 flex items-center justify-center text-4xl">
              {member.icon}
            </div>
            <h3 class="text-lg font-semibold text-navy-900 mb-1">{member.role}</h3>
            <p class="text-sm text-slate-500">{serviceData.company.team_subtitle}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="gradient-navy section-padding">
    <div class="container-default text-center">
      <h2 class="text-2xl md:text-3xl font-bold text-white mb-4 animate-on-scroll">{t('cta.title', lang)}</h2>
      <p class="text-slate-300 mb-8 max-w-2xl mx-auto animate-on-scroll">{t('cta.subtitle', lang)}</p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center animate-on-scroll">
        <a href={translatePath('contact')} class="btn-secondary">{t('cta.cta_consultation', lang)}</a>
        <a href="https://wa.me/34972000000" target="_blank" rel="noopener noreferrer" class="btn-outline-light">{t('cta.cta_whatsapp', lang)}</a>
      </div>
    </div>
  </section>
</PageLayout>
