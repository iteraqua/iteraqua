---
import BaseLayout from './BaseLayout.astro';
import type { Language, RouteId } from '@/i18n/utils';
import { getLocalizedPath, getRouteIdFromPath, t } from '@/i18n/utils';
import { generateBreadcrumbSchema, SITE_URL } from '@/utils/seo';

interface Props {
  title: string;
  description: string;
  lang: Language;
  path: string;
  image?: string;
  heroTitle?: string;
  heroSubtitle?: string;
  breadcrumbs?: { label?: string; href?: string; routeId?: RouteId }[];
  type?: 'website' | 'article';
  publishedDate?: string;
  modifiedDate?: string;
  structuredData?: object[];
}

const {
  title,
  description,
  lang,
  path,
  image,
  heroTitle,
  heroSubtitle,
  breadcrumbs = [],
  type = 'website',
  publishedDate,
  modifiedDate,
  structuredData = [],
} = Astro.props;

const breadcrumbLabelKeys: Partial<Record<RouteId, string>> = {
  home: 'nav.home',
  company: 'nav.company',
  services: 'nav.services',
  'services.portMaintenance': 'nav.services_port_maintenance',
  'services.underwaterWorks': 'nav.services_underwater_works',
  'services.maritimeEngineering': 'nav.services_maritime_engineering',
  'services.coastalEngineering': 'nav.services_coastal_engineering',
  'services.hydraulicInfrastructure': 'nav.services_hydraulic_infrastructure',
  'services.underwaterInspections': 'nav.services_underwater_inspections',
  projects: 'nav.projects',
  blog: 'nav.blog',
  certifications: 'nav.certifications',
  contact: 'nav.contact',
  privacy: 'legal.privacy_title',
  cookies: 'legal.cookies_title',
  legal: 'legal.legal_title',
};

const normalizeBreadcrumbHref = (href: string): string => {
  const url = href.startsWith('http') ? new URL(href) : new URL(href, SITE_URL);
  const pathname = url.pathname.replace(/\/+$/, '') || '/';
  return `${pathname}${url.search}${url.hash}`;
};

const resolveBreadcrumb = (crumb: NonNullable<Props['breadcrumbs']>[number]) => {
  const route = crumb.routeId
    ? { routeId: crumb.routeId, params: {} }
    : crumb.href
      ? getRouteIdFromPath(normalizeBreadcrumbHref(crumb.href))
      : undefined;

  const href = route ? getLocalizedPath(route.routeId, lang, route.params) : normalizeBreadcrumbHref(crumb.href ?? '/');
  const labelKey = route ? breadcrumbLabelKeys[route.routeId] : undefined;
  const label = labelKey ? t(labelKey, lang) : (crumb.label ?? '');

  return { label, href };
};

const normalizedBreadcrumbs = breadcrumbs.map(resolveBreadcrumb);
const breadcrumbSchema = normalizedBreadcrumbs.length > 0
  ? generateBreadcrumbSchema(
      normalizedBreadcrumbs.map((crumb) => ({
        name: crumb.label,
        url: `${SITE_URL}${crumb.href}`,
      }))
    )
  : null;

const allStructuredData = [...structuredData, ...(breadcrumbSchema ? [breadcrumbSchema] : [])];
---

<BaseLayout
  title={title}
  description={description}
  lang={lang}
  path={path}
  image={image}
  type={type}
  publishedDate={publishedDate}
  modifiedDate={modifiedDate}
  structuredData={allStructuredData}
>
  {heroTitle && (
    <section class="gradient-navy relative overflow-hidden">
      <div class="absolute inset-0 bg-[url('/images/pattern-waves.svg')] opacity-5"></div>
      <div class="container-default relative py-16 md:py-20 lg:py-28">
        {normalizedBreadcrumbs.length > 0 && (
          <nav aria-label="Breadcrumb" class="mb-6">
            <ol class="flex items-center gap-2 text-sm text-slate-300">
              {normalizedBreadcrumbs.map((crumb, index) => (
                <li class="flex items-center gap-2">
                  {index > 0 && <span aria-hidden="true">/</span>}
                  {index < normalizedBreadcrumbs.length - 1 ? (
                    <a href={crumb.href} class="hover:text-aqua-400 transition-colors">{crumb.label}</a>
                  ) : (
                    <span class="text-aqua-400" aria-current="page">{crumb.label}</span>
                  )}
                </li>
              ))}
            </ol>
          </nav>
        )}
        <h1 class="text-3xl md:text-4xl lg:text-5xl font-bold text-white text-balance">{heroTitle}</h1>
        {heroSubtitle && (
          <p class="mt-4 text-lg md:text-xl text-slate-300 max-w-3xl text-pretty">{heroSubtitle}</p>
        )}
      </div>
    </section>
  )}

  <slot />
</BaseLayout>
